                "transliteration": "ḥr nḏ-ḫr.t n sn.t=j m-bꜣḥ jty",
                "hieroglyph": "𓁷𓏤𓄔𓈖𓆑𓂋𓏏𓈖𓊃𓈖𓏏𓁐𓇋𓏠𓈖𓐝𓄂𓏤𓇋𓏏𓏭𓆑",
                "entity_type": "sentence"
            },
            "layer2_languages": {
                "arabic": "السطر L01: أرسل وافر السلام والتحية لأختي الكريمة أمام جلالة وسلطان الملك سيدي،",
                "english": "Line L01: Sending greetings of welfare to my sister before the majesty of my lord,",
                "german": "Zeile L01: Senden von Grüßen des Wohlergehens an meine Schwester vor der Majestät meines Herrn,",
                "french": "Ligne L01: Envoi de salutations de bien-être à ma sœur devant la majesté de mon seigneur,",
                "coptic": "unknown",
                "akkadian": "unknown"
            },
            "layer3_grammar": {
