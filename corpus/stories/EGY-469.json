                "transliteration": "jw r-f wn m-dỉ.t sn.w ḥnˁ sn.wt jm",
                "hieroglyph": "𓇋𓅱𓂋𓆑𓅱𓈖𓐝𓂞𓏏𓊃𓈖𓏲𓏪𓎛𓈖𓂝𓊃𓈖𓏲𓏏𓏪𓐝𓆑",
                "entity_type": "sentence"
            },
            "layer2_languages": {
                "arabic": "السطر L02: وتأكدي أنه لا يزال لديكِ إخوة وأخوات كرام يرعونك ويسألون عنك هناك،",
                "english": "Line L02: and indeed, you still have brothers and sisters with you there,",
                "german": "Zeile L02: und in der Tat, du hast dort immer noch Brüder und Schwestern bei dir,",
                "french": "Ligne L02: et en effet, tu as toujours des frères et sœurs avec toi là-bas,",
                "coptic": "unknown",
                "akkadian": "unknown"
