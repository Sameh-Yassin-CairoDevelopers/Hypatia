                "transliteration": "m-dy jr.y=j ṯtṯt jrm=k ḥr jḫt nb.t",
                "hieroglyph": "𓐝𓂞𓁹𓇋𓏠𓈖𓍿𓍿𓏏𓇋𓏠𓈖𓐝𓇋𓂋𓏠𓎡𓁷𓏤𓐍𓏏𓎟𓏏",
                "entity_type": "sentence"
            },
            "layer2_languages": {
                "arabic": "السطر L03: فلا تجعليني أدخل في شقاق أو شجار معك بسبب أي شيء مادي زائل بالدنيا،",
                "english": "Line L03: Do not make me quarrel with you on account of anything,",
                "german": "Zeile L03: Lass mich nicht wegen irgendetwas mit dir streiten,",
                "french": "Ligne L03: Ne me fais pas me quereller avec toi à cause de quoi que ce soit,",
                "coptic": "unknown",
                "akkadian": "unknown"
