            "layer1_core": {
                "text_id": "EGY-167",
                "sequence_no": 9,
                "transliteration": "jr hrw nfr smḫ qrs.t=k j-mỉ ˁntyw ḥr tp=k wnm.k m sš.w",
                "hieroglyph": "𓁹𓁷𓏤𓄤𓋴𓐝𓆄𓈎𓂋𓋴𓏏𓎡𓇋𓐝𓎛𓎿𓁷𓏤𓏏𓏪𓎡𓅱𓈖𓐝𓎡𓐝𓋴𓏟𓏲𓏥",
                "entity_type": "sentence"
            },
            "layer2_languages": {
                "arabic": "لذلك، اجعل يومك سعيداً ومبهجاً وعش في رضاء كامل! ضع العطر الفاخر على رأسك والبس الكتان الناعم المنسوج للآلهة.",
