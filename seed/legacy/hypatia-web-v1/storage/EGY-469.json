            },
            "layer2_languages": {
                "arabic": "السطر 1: أرسل وافر السلام والتحية لأختي الكريمة أمام جلالة وسلطان الملك سيدي،",
                "english": "Line 1: Sending greetings of welfare to my sister before the majesty of my lord,",
                "german": "Zeile 1: Senden von Grüßen des Wohlergehens an meine Schwester vor der Majestät meines Herrn,",
                "french": "Ligne 1: Envoi de salutations de bien-être à ma sœur devant la majesté de mon seigneur,",
                "coptic": "unknown",
                "akkadian": "unknown"
            },
